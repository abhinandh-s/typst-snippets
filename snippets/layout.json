{
  "align center": {
    "prefix": "align.c",
    "body": [
      "#align(center)[",
      "\t${1:para}",
      "]"
    ],
    "description": "Align contents center."
  },
  "align right bottom": {
    "prefix": "align.r.b",
    "body": [
      "#align(right + bottom)[",
      "\t${0:para}",
      "]"
    ],
    "description": "Align contents towards right bottom."
  },
  "block": {
    "prefix": "block",
    "body": [
      "#block(",
        "\tfill: luma(230),",
        "\tinset: 8pt,",
        "\tradius: 4pt,",
        ")[${0:text}]"
    ],
    "description": "A block-level container."
  },
  "box": {
    "prefix": "box",
    "body": [
      "#box(",
        "\tinset: 4pt,",
        ")[${0:text}]"
    ],
    "description": "An inline-level container that sizes content."
  },
  "pagebreak": {
    "prefix": "pagebreak",
    "body": [
      "#pagebreak(",
        "\tweak: false,",
        "\tto: \"${0:odd}\",",
        ")"
    ],
    "description": [
      "A manual page break.",
      " ",
      "Must not be used inside any containers.",
      " ",
      "PARAMETERS:",
      " ",
      "weak: bool",
      " ",
      "If true, the page break is skipped if the current page is already empty.",
      " ",
      "Default: false",
      " ",
      "to: none or str",
      " ",
      "If given, ensures that the next page will be an even/odd page, with an empty page in between if necessary.",
      " "
    ]
  }
}
